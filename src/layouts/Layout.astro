---
import { ClientRouter } from 'astro:transitions';

import BetterIcon from '../components/ui/BetterIcon.astro'
import DarkLightController from '../components/ui/DarkLightController.astro'
import ThemeSelector from '../components/ui/ThemeSelector.astro'
import Navbar from '../components/ui/Navbar.astro'
import Head from '../components/Head.astro'

import { seo, profile, template } from '../settings'
import Footer from '../components/ui/Footer.astro'

type Props = {
	title?: string
	description?: string
	image?: string
}

const {
	title = seo.default_title,
	description = seo.default_description,
	image = seo.default_image,
} = Astro.props
---

<!doctype html>
<html lang='en'>
	<head>
		{template.transitions && <ClientRouter /> }

		<Head title={title} description={description} image={image} />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap"
		/>

	</head>
	<body class='text-[16px] bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-slate-50'>
		<div>
			<!-- Top bar -->
	            <div>
				<div class='backdrop-blur bg-slate-900/80 z-50 border-b border-slate-800/70'>
					<nav class='navbar max-w-6xl mx-auto px-4'>
						<div class='flex-1 text-sm uppercase tracking-[0.25em] text-slate-300'>
							<span class='font-semibold text-slate-100'>{profile.fullName}</span>
							<span class='hidden sm:inline'>&nbsp;·&nbsp;Autonomous Systems &amp; Control</span>
						</div>
						<ul class='flex items-center gap-6 text-xs sm:text-sm text-slate-300'>
							<li><a href={template.base} class='hover:text-slate-50 transition-colors'>Home</a></li>
							<li><a href={`${template.base}research`} class='hover:text-slate-50 transition-colors'>Research</a></li>
							<li><a href={`${template.base}papers`} class='hover:text-slate-50 transition-colors'>Papers</a></li>
							<li><a href={`${template.base}cv`} class='hover:text-slate-50 transition-colors'>CV</a></li>
						</ul>
					</nav>
				</div>
                <main class='p-6 lg:p-10 max-w-6xl mx-auto min-h-screen flex flex-col gap-12'>
					<!-- Page content -->
					<slot />
				<Footer />
				</main>
		</div>
	</body>
</html>

<style>
	@media (prefers-color-scheme: dark) {
		:root {
			--my-color: #252b30;
		}
	}
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: 'Roboto', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}
</style>
