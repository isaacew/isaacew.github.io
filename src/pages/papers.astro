---
import Layout from "@/layouts/Layout.astro";
import { highlightAuthor } from "@/lib/utils";
import { template } from "@/settings";
import { getPublications } from "@/lib/publications";

const ALL_PAPERS = getPublications();
---

<Layout title="Papers">
  <div>
	<h1 class="text-3xl font-bold mb-4">Publications</h1>

    <div class="mb-4 max-w-2xl">
      <input
        id="papers-search"
        type="text"
        placeholder="Search: title, author, or venue"
        class="w-full border border-base-300 bg-base-200 text-[1.5rem] px-4 py-2 outline-none"
        aria-label="Search publications"
      />
    </div>

    <div id="papers-list" class="grid gap-8 justify-center">
      {
        ALL_PAPERS.map((paper) => (
          <a href={`${template.base}publications/${paper.id}`} class="no-underline">
          <div class="bg-base-200 hover:bg-base-300/80 transition-colors w-full">
            <div class="grid md:grid-cols-[minmax(0,2.8fr)_minmax(0,1.2fr)] grid-cols-1 items-stretch">
              <div class="p-1.5">
                <h2 class="text-[1.5rem] font-semibold">
                  {paper.title}
                </h2>
                <p class="text-[1rem] text-base-content/80">
                  <span
                    set:html={highlightAuthor(
                      Array.isArray(paper.authors) ? paper.authors.join(', ') : paper.authors || ''
                    )}
                  />
                </p>
                <p class="text-[1rem] text-base-content/70">
                  <span class="italic">{paper.venue}</span>
                  {paper.year && ` • ${paper.year}`}
                </p>
                <div class="flex flex-wrap gap-1 mt-1">
                  {paper.preprintUrl && (
                    <a
                      href={paper.preprintUrl}
                      class="btn btn-xs btn-accent text-accent-content"
                      target="_blank"
                    >
                      preprint
                    </a>
                  )}
                  {paper.doi && (
                    <a
                      href={paper.doi.startsWith('http') ? paper.doi : `https://doi.org/${paper.doi}`}
                      class="btn btn-xs btn-primary text-primary-content"
                      target="_blank"
                    >
                      DOI
                    </a>
                  )}
                  {paper.url && (
                    <a
                      href={paper.url}
                      class="btn btn-xs btn-secondary text-secondary-content"
                      target="_blank"
                    >
                      url
                    </a>
                  )}
                  {paper.codeUrl && (
                    <a
                      href={paper.codeUrl}
                      class="btn btn-xs btn-outline"
                      target="_blank"
                    >
                      Code
                    </a>
                  )}
                  {paper.hasLocalPaper && (
                    <a
                      href={`${template.base}publications/${paper.id}/paper.pdf`}
                      class="btn btn-xs btn-neutral text-neutral-content"
                      target="_blank"
                    >
                      paper
                    </a>
                  )}
                </div>
                {paper.bibtex && (
                  <details class="mt-1">
                    <summary class="cursor-pointer text-[0.75rem] text-accent">BibTeX</summary>
                    <pre class="whitespace-pre-wrap text-[0.75rem] bg-base-200 max-h-36 overflow-auto">
{paper.bibtex}
                    </pre>
                  </details>
                )}
              </div>
              <div class="flex items-center justify-center p-1.5 thumb-wrapper">
                <div class="w-[110px] h-[110px] bg-base-300 flex items-center justify-center overflow-hidden">
                  <img
                    src={`/content/publications/${paper.id}/feature.png`}
                    alt={paper.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                    onError={(event) => {
                      const img = event.currentTarget as HTMLImageElement;
                      const wrapper = img.closest('.thumb-wrapper') as HTMLElement | null;
                      if (wrapper) {
                        wrapper.style.display = 'none';
                      }
                    }}
                  />
                </div>
              </div>
            </div>
          </div>
          </a>
        ))
      }
    </div>

    <script is:inline>
      const list = document.getElementById('papers-list');

      if (list) {
        const cards = Array.from(list.children);

        const normalize = (str) =>
          (str || '').toString().toLowerCase();

        const searchInput = document.getElementById('papers-search');
        if (searchInput) {
          searchInput.addEventListener('input', () => {
            const term = normalize(searchInput.value);
            cards.forEach((card) => {
              const text = normalize(card.textContent);
              card.style.display = term === '' || text.includes(term) ? '' : 'none';
            });
          });
        }
      }
    </script>
  </div>
</Layout>
