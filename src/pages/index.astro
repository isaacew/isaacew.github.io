---
import Layout from '../layouts/Layout.astro'

import { profile } from '@/settings'
import { publications } from '@/data/cv'
import ProfilePictures from '@/assets/me.png'
import Hero from '@/components/ui/Hero.astro'
import Grid from '@/components/ui/Grid.astro'
import ArticleList from '@/components/ui/ArticleList.astro'

const { fullName, title, institute, research_areas } = profile

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<!-- Hero Section -->
	<section class='flex flex-col lg:flex-row items-stretch gap-10 lg:gap-16 rounded-3xl border border-slate-800/70 bg-gradient-to-br from-slate-900/80 via-slate-950/90 to-slate-900/80 px-6 lg:px-10 py-10 lg:py-14 shadow-2xl shadow-black/40'>
		<Hero
			fullName={fullName}
			title={title}
			institute={institute}
			profilePicture={ProfilePictures}
		/>
		<div class='hidden lg:flex flex-1 items-center justify-center'>
			<div class='w-full h-64 rounded-3xl bg-gradient-to-tr from-emerald-500/40 via-cyan-400/40 to-indigo-500/40 border border-emerald-300/40 shadow-[0_0_80px_rgba(16,185,129,0.35)] flex items-center justify-center text-sm tracking-wide uppercase text-emerald-50/90'>
				Placeholder for research animation / orbit visualization
			</div>
		</div>
	</section>

	<!-- Research Areas -->
	<section class='py-12'>
		<Grid gridTitle='Research Areas' gridItems={research_areas} />
	</section>

	<!-- Recent Publications -->
	<section class='py-12 border-t'>
		<ArticleList listTitle='Recent Publications' listItems={publications} />
	</section>
</Layout>
