---
import Layout from "@/layouts/Layout.astro";
import { profile } from "@/settings";
import BetterIcon from "@/components/ui/BetterIcon.astro";
import { RESEARCH_ICONS } from "@/data/researchIcons";
import { getPublications } from "@/lib/publications";

const { research_areas } = profile;
const publications = getPublications();
---

<Layout title="Research | Isaac Weintraub">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-8">Research</h1>

    <div class="mb-12">
      <p class="text-lg mb-6">
        My research focuses on automation and control of aerospace systems for defense applications, with particular emphasis on pursuit-evasion differential games, multi-agent cooperation, and guidance and control for autonomous systems.
      </p>
    </div>

    <h2 class="text-2xl font-bold mb-6">Research Areas</h2>
    <div class="grid gap-8 mb-12">
      {
        research_areas.map((area) => (
          <div class="flex gap-6 items-start">
            <BetterIcon>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2"
                class="size-6 stroke-accent"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={RESEARCH_ICONS[area.field as keyof typeof RESEARCH_ICONS]?.path || RESEARCH_ICONS["engineering"].path}
                />
              </svg>
            </BetterIcon>
            <div>
              <h3 class="text-xl font-semibold mb-2">{area.title}</h3>
              <p class="text-base">{area.description}</p>
            </div>
          </div>
        ))
      }
    </div>

    {publications.length > 0 && (
      <>
        <h2 class="text-2xl font-bold mb-6">Selected Publications</h2>
        <div class="grid gap-8 mb-12 md:grid-cols-2">
          {publications.map((pub) => (
              <div class="card bg-base-200 shadow-md h-full">
                <figure class="h-40 flex items-center justify-center text-5xl">
                  📄
                </figure>
                <div class="card-body">
                  <h3 class="card-title text-lg">{pub.title}</h3>
                  <p class="text-sm text-base-content/80">
                    {pub.authors.join(", ")}
                  </p>
                  <p class="text-sm text-base-content/70">
                    {pub.venue} {pub.year && `(${pub.year})`}
                  </p>
                  {pub.abstract && (
                    <p class="text-sm mt-2 line-clamp-4">
                      {pub.abstract}
                    </p>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</Layout>
