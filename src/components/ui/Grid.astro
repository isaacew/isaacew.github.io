---
interface Props {
  gridTitle: string;
  gridItems: {
    title: string;
    description: string;
  }[];
}

const {gridTitle, gridItems} = Astro.props;
---
<h2 class="text-3xl font-bold mb-6 tracking-tight">{gridTitle}</h2>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  {gridItems.map((item) => (
    <div class="p-6 rounded-2xl bg-slate-900/70 border border-slate-800/80 shadow-lg shadow-black/40 hover:-translate-y-1 hover:border-slate-500/70 transition-all duration-300">
      <h3 class="text-xl font-semibold mb-2 text-slate-50">{item.title}</h3>
      <p class="text-sm text-slate-300 leading-relaxed">{item.description}</p>
    </div>
  ))}
</div>
