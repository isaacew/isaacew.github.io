---
import { Image } from 'astro:assets'

import SocialIcons from './SocialIcons.astro'


const {fullName, title, institute, profilePicture} = Astro.props
---
<div class='flex-1'>
  <h1 class='text-4xl font-bold mb-4'>
    Welcome! I'm <span class='text-secondary'>{fullName}</span>
  </h1>
  <p class='text-xl text-gray-300 mb-3'>
    {title}
    {institute && <span class='block text-lg text-gray-400'>{institute}</span>}
  </p>
  <p class='text-lg mb-4 text-gray-200'>
    I work at the intersection of guidance, control, and multi-agent decision making for autonomous aerospace systems. My research focuses on pursuitevasion differential games, cooperative engagement strategies, and resilient control of unmanned aircraft teams operating in contested environments.
  </p>
  <p class='text-sm mb-6 text-gray-400'>
    I received my PhD in Electrical Engineering from the Air Force Institute of Technology (2021), an M.S. in Electrical Engineering from the University of Texas at Arlington (2011), and a B.S. in Mechanical Engineering from RoseHulman Institute of Technology (2009). I am an associate fellow of AIAA and a senior member of IEEE, with active involvement in technical communities on intelligent systems, robotics, and control.
  </p>
  <div class='flex gap-4'>
    <SocialIcons />
  </div>
</div>
<div class='size-72 lg:block hidden'>
  <!-- Add your profile image -->
  <Image
    src={profilePicture}
    alt={fullName}
    class='w-full h-full mask mask-circle size-44'
  />
</div>
