---
import { Image } from 'astro:assets';
import ProfilePortrait from '../assets/me.png';
import SocialIcons from '../components/SocialIcons.astro'

import {
  kSiteTitle,
  kSiteIndexTitle,
  kJobTitle,
  kUrlBase,
} from "$consts";
---

<header>
  <div class="w3-sidebar w3-bar-block w3-collapse w3-card sidepanel" style="width:300px;" id="mySidebar">
        <button class="w3-bar-item w3-button w3-hide-large" id="closebutton">Close &times;</button>
        <div align="center" style="padding-top: 20px">
        <div>
        <Image
            class='mask3'
            src={ProfilePortrait}
            alt={`Picture of ${kSiteIndexTitle}`}
            width=160
            >
        </div>
        <b style="font-size: 18px;">{kSiteTitle}</b>
        </div>
        <div align="left">
        <p>
            {kJobTitle}
        </p>
        </div>
        <nav class="sidebar-nav">
          <a href={`${kUrlBase}/`}>Home</a>
          <a href={`${kUrlBase}/research`}>Research</a>
          <a href={`${kUrlBase}/cv`}>CV</a>
        </nav>
        <SocialIcons />
    </div>
</header>
<style>
  .sidepanel {
    background-color: var(--main-bg-color);
    color: var(--main-fg-color);
    padding: 20px;
  }
  .mask3 {
      /* -webkit-mask-image: radial-gradient(ellipse, black 50%, rgba(0, 0, 0, 0.5) 50%); */
      /* mask-image: radial-gradient(ellipse, black 70%, rgba(0, 0, 0, 0.0) 50%); */
    clip-path: ellipse(50% 50% at 50% 50%);
  }
  .sidebar-nav {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .sidebar-nav a {
    display: block;
    padding: 0.25rem 0;
    color: var(--main-color);
    text-decoration: none;
  }
  .sidebar-nav a:hover {
    color: var(--main-hover-color);
    text-decoration: underline;
  }
</style>

<script>
  const close = document.getElementById("closebutton")

  closebutton?.addEventListener("click", () => {
    document.getElementById("mySidebar").style.display = "none";
  })

</script>
